{
  "name": "urbanscope",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "cmd /c npm run dev --workspace frontend",
    "dev:backend": "cmd /c npm run dev --workspace backend",
    "build": "cmd /c npm run build --workspace frontend && cmd /c npm run build --workspace backend",
    "lint": "cmd /c npm run lint --workspace frontend"
  }
}

